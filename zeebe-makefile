####################
# Part 0. Let's download the certs from k8s secret
####################
# 0.a. Four certs are download via these commands
# cert-public-c8-labs.key (public key)
kubectl get secret c8-labs-init-certs -n c8-labs-ingress-nginx  -o jsonpath='{.data.cert-public-c8-labs\.key}' | base64 -d > cert-public-c8-labs.key

# cert-key-c8-labs.key (privae key)
kubectl get secret c8-labs-init-certs -n c8-labs-ingress-nginx  -o jsonpath='{.data.cert-key-c8-labs\.key}' | base64 -d > cert-key-c8-labs.key

# cert-origin_ca_rsa_root.pem
kubectl get secret c8-labs-init-certs -n c8-labs-ingress-nginx -o jsonpath='{.data.cert-origin_ca_rsa_root\.pem}' | base64 -d > cert-origin_ca_rsa_root.pem

# cert-fullchain-c8-labs.pem
kubectl get secret c8-labs-init-certs -n c8-labs-ingress-nginx  -o jsonpath='{.data.cert-fullchain-c8-labs\.pem}' | base64 -d > cert-fullchain-c8-labs.pem

# cert0.pem cert1.pem cert2.pem
kubectl get secret c8-labs-init-certs -n c8-labs-ingress-nginx  -o jsonpath='{.data.cert0\.pem}' | base64 -d > cert0.pem
kubectl get secret c8-labs-init-certs -n c8-labs-ingress-nginx  -o jsonpath='{.data.cert1\.pem}' | base64 -d > cert1.pem
kubectl get secret c8-labs-init-certs -n c8-labs-ingress-nginx  -o jsonpath='{.data.cert2\.pem}' | base64 -d > cert2.pem


kubectl create secret generic custom-ca --from-file=ca.crt=./cert-origin_ca_rsa_root.pem -n ${UNAMESPACE}

# Add cert files as secrets
kubectl create secret tls cf-origin-cert  --cert=cert-public-c8-labs.key   --key=cert-key-c8-labs.key -n ${UNAMESPACE}
kubectl create secret tls cf-full-chain-origin-cert  --cert=cert-fullchain-c8-labs.pem --key=cert-key-c8-labs.key -n ${UNAMESPACE}


####################
# Part 1. Prepare env for Zeebe
####################
# 1.a. Generate a pkcs8 key from current private key
printf "pkcs8 key generation from private key"
openssl pkcs8 -topk8 -nocrypt -in ./cert-key-c8-labs.key  -out ./${UNAMESPACE}-zeebe-key-pkcs8.pem

# 1.b. Combine public cert + pkcs8 private key into PKCS#12
# cert-public-c8-labs.key -> this is in pem format
openssl pkcs12 -export -in cert-public-c8-labs.key -inkey ./${UNAMESPACE}-zeebe-key-pkcs8.pem -name ${UNAMESPACE}-zeebe -out ${UNAMESPACE}-zeebe.p12  -password pass:changeit

# 2. Import PKCS#12 into a JKS keystore
keytool -importkeystore -deststorepass changeit -destkeypass changeit -destkeystore ${UNAMESPACE}-zeebe.jks -srckeystore ${UNAMESPACE}-zeebe.p12 -srcstoretype PKCS12 -srcstorepass changeit   -alias ${UNAMESPACE}-zeebe

# 3. Create Kubernetes secret
kubectl create secret generic ${UNAMESPACE}-zeebe-jks --from-file=${UNAMESPACE}-zeebe.jks   -n ${UNAMESPACE}

# 4. Create Kubernetes secret - public CA root cert needed for spring-boot ca.crt
kubectl create secret generic ${UNAMESPACE}-zeebe-ca-crt --from-file=ca.crt=./cert-origin_ca_rsa_root.pem   -n ${UNAMESPACE} 

# 5. Create Kubernetes secret - public cert with fullchain and pkcs8 secret. For zeebe use.
# Ref https://docs.camunda.io/docs/self-managed/zeebe-deployment/security/secure-cluster-communication/
kubectl create secret generic ${UNAMESPACE}-zeebe-tls -n ${UNAMESPACE} --from-file=tls.crt=cert-fullchain-c8-labs.pem  --from-file=tls.key=./${UNAMESPACE}-zeebe-key-pkcs8.pem --from-file=ca.crt=cert-origin_ca_rsa_root.pem

kubectl create secret tls ${UNAMESPACE}-zeebe-grpc-tls -n ${UNAMESPACE} --cert=cert-fullchain-c8-labs.pem  --key=${UNAMESPACE}-zeebe-key-pkcs8.pem 
kubectl create secret tls ${UNAMESPACE}-zeebe-rest-tls -n ${UNAMESPACE} --cert=cert-fullchain-c8-labs.pem  --key=${UNAMESPACE}-zeebe-key-pkcs8.pem 


####################
# Part 2. Prepare env for Toolkit app
####################

# Instead of copy command, lets create a new jks file for toolkit app. See next two command lines below.
cp ${UNAMESPACE}-zeebe.jks  ${UNAMESPACE}-zeebe-toolkit.jks

# 6. Toolkit app requires a key store, that includes leaft cert, intermediate cert and root cert.
# Make sure three files are in the current folder. See the instructions in runbook-e-deployment bpmn.
keytool -importcert -trustcacerts -alias server-cert        -file cert0.pem -keystore ${UNAMESPACE}-zeebe-toolkit.jks -storepass changeit --noprompt
keytool -importcert -trustcacerts -alias intermediate-cert  -file cert1.pem -keystore ${UNAMESPACE}-zeebe-toolkit.jks -storepass changeit --noprompt
keytool -importcert -trustcacerts -alias root-cert          -file cert2.pem -keystore ${UNAMESPACE}-zeebe-toolkit.jks -storepass changeit --noprompt

# lets add the ca cert as well to jks
keytool -importcert -alias ml-ca -file cert-origin_ca_rsa_root.pem -keystore ${UNAMESPACE}-zeebe-toolkit.jks -storepass changeit -noprompt

kubectl create secret generic ${UNAMESPACE}-zeebe-toolkit-jks  --from-file=${UNAMESPACE}-zeebe-toolkit.jks   -n ${UNAMESPACE}

# Debug any issue with toolkit ca cert.
#kubectl get secret ${UNAMESPACE}-zeebe-toolkit-jks -n ${UNAMESPACE}  -o jsonpath='{.data.c8-labs-32-zeebe-toolkit\.jks}' | base64 -d > ${UNAMESPACE}-zeebe-toolkit.jks
#keytool -exportcert   -alias ml-ca   -keystore ml-toolkit.jks   -rfc   -file ml-ca.crt


####################
# Part 3. Prepare env for keycloak
####################
# 7.a. keycloak config - public cert and associated key
kubectl create secret generic keycloak-certificates-tls-secret  --from-file=./cert-public-c8-labs.key  --from-file=./cert-key-c8-labs.key -n ${UNAMESPACE}

# 7.b. keycloak config - prepare jks with two steps ->> keycloak-keystore.jks
openssl pkcs12 -export -in ./cert-public-c8-labs.key -inkey ./cert-key-c8-labs.key -out keycloak-keystore.p12 -name keycloak -CAfile cert-origin_ca_rsa_root.pem  -caname root -password pass:changeit 
keytool -importkeystore -destkeystore keycloak-keystore.jks -srckeystore keycloak-keystore.p12 -srcstoretype pkcs12 -alias keycloak -storepass changeit -srcstorepass changeit --noprompt

# 7.c. lets create trust store ->> keycloak-truststore.jks
keytool -importcert -alias ml-ca -file cert-origin_ca_rsa_root.pem -keystore keycloak-truststore.jks -storepass changeit -noprompt

# 7.d. lets create a secret with keystore and truststore. along with respetive store password
kubectl create secret generic keycloak-jks-truststore-secret --from-file=keycloak.keystore.jks=./keycloak-keystore.jks --from-file=keycloak.truststore.jks=./keycloak-truststore.jks   --from-file=tls.crt=./cert-public-c8-labs.key  --from-file=tls.key=./cert-key-c8-labs.key  -n ${UNAMESPACE}
# --from-literal=keystore-password='changeit' --from-literal=truststore-password='changeit'


####################
# Part 4. Prepare env for console
####################
# 8. console config
kubectl create secret generic console-certificates-tls-secret  --from-file=./cert-public-c8-labs.key  --from-file=./cert-key-c8-labs.key -n ${UNAMESPACE}


# Cleanup at the end
rm -f ${UNAMESPACE}-zeebe.p12  ${UNAMESPACE}-zeebe.jks  ./${UNAMESPACE}-zeebe-key-pkcs8.pem ./${UNAMESPACE}-zeebe-toolkit.jks
rm -f keycloak-keystore.jks keycloak-keystore.p12 keycloak-truststore.jks
rm -f ${UNAMESPACE}-zeebe-toolkit.p12