# Build "toolkit" maven java project 
cd toolkit
mvn clean package -DskipTests

# Build docker image
docker build -t asia-south2-docker.pkg.dev/c8-labs/c8-labs-repo/toolkit-c8-labs-32:v1 .


# Authenticate docker to push to GCR
#gcloud auth configure-docker asia-south2-docker.pkg.dev
#docker tag  toolkit-c8-labs-32 asia-south2-docker.pkg.dev/c8-labs/c8-labs-repo/toolkit-c8-labs-32:v1
docker push                   asia-south2-docker.pkg.dev/c8-labs/c8-labs-repo/toolkit-c8-labs-32:v1
cd ..

#################
# Lastly, install toolkit app and bpmn solution artifacts -bpmn, dmn, form
# Lets come back to the home folder and run deploy script to GKE
kubectl apply -f deploy-worker-toolkit.yaml -n c8-labs-32

kubectl describe service toolkit-service -n c8-labs-32


cd 1-lead-to-opportunity-dmn-form-webhook/
zbctl deploy --address "c8-labs-32-zeebe-gw.makelabs.in:80" --insecure lead-to-opportunity-with-dmn.bpmn
zbctl deploy --address "c8-labs-32-zeebe-gw.makelabs.in:80" --insecure new-lead-approval.dmn
zbctl deploy --address "c8-labs-32-zeebe-gw.makelabs.in:80" --insecure lead-to-opportunity-with-webhook-Form.form
cd ..

# Run this when you are ready to deploy the toolkit app.
kubectl apply -f c8-ingress-with-toolkit.yaml --namespace c8-labs-32

# This concludes the toolkit app deployment and bpmn solution artifacts.

