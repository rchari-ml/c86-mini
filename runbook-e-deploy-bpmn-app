#Above command prints leaf cert, intermediate cert and root cert


###### Method 2
## step 1 check fingerprint
openssl x509 -in  cert-public-c8-labs.key -noout -fingerprint -sha256
## step 2 see if the public cert fingerprint is valid in the jks file
keytool -list -v -keystore c8-labs-32-zeebe-toolkit.jks | grep -i "SHA256"
# Expected outcome: The step 1 fingerprint should be listed in the step 2 output list.


###### Method 3
# here are steps to generate JKS that includes all certs. See Method 1 for info.
openssl s_client -connect c8-labs-32-zeebe-gateway.makelabs.in:443 -showcerts </dev/null > c8-labs-32-zeebe-fullchain.pem
# This command below is supposed to create three files. There was an error at this step.
# Hence, do the file creation manually from the fullchain pem file.
csplit -f cert c8-labs-32-zeebe-fullchain.pem '/-----BEGIN CERTIFICATE-----/' '{*}'
mv cert00 cert0.pem
mv cert01 cert1.pem
mv cert02 cert2.pem

# verify the issuer
openssl x509 -in cert0.pem -noout -subject -issuer
openssl x509 -in cert1.pem -noout -subject -issuer
openssl x509 -in cert2.pem -noout -subject -issuer

# Finally, lets create JKS with the files thus created above.
keytool -importcert -trustcacerts -alias server-cert        -file cert0.pem -keystore c8-labs-32-zeebe.jks -storepass changeit
keytool -importcert -trustcacerts -alias intermediate-cert  -file cert1.pem -keystore c8-labs-32-zeebe.jks -storepass changeit
keytool -importcert -trustcacerts -alias root-cert          -file cert2.pem -keystore c8-labs-32-zeebe.jks -storepass changeit


## How to check cert full chain?
# create a full chain cert file that is origin cert + origin ca cert. After this, you can verify the cert chain.
cat cert-public-c8-labs.key  cert-origin_ca_rsa_root.pem  > cert-fullchain-c8-labs.pem
openssl verify -CAfile cert-fullchain-c8-labs.pem  cert-fullchain-c8-labs.pem 

