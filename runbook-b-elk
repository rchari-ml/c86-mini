# Login to GCP console if required
gcloud auth login

# Using CLI, know current user name
gcloud config get-value account

# Check if the user can see the cluster - via Project Lens UI app
gcloud container clusters describe c8-labs-sravana --region asia-south2 --project c8-labs
gcloud container clusters get-credentials c8-labs-sravana --region asia-south2 --project c8-labs

# replace user id, email, token appropriately
kubectl create secret docker-registry registry-camunda-cloud  \
  --namespace=c8-labs-32 \
  --docker-server=registry.camunda.cloud \
  --docker-username=your-docker-account-uid \
  --docker-password=your-docker-account-token \
  --docker-email=your-docker-account-email

# replace user id, email, token appropriately
kubectl create secret docker-registry registry-docker-hub  \
    --namespace=c8-labs-32 \
    --docker-server=hub.docker.com \
    --docker-username=your-docker-account-uid \
    --docker-password=your-docker-account-token \
    --docker-email=your-docker-account-email


# Install elastic components - elk certs
sh elk-makefile
# After this, you should see secrets created in the namespace c8-labs-32
# Config => secret/elastic-certificates created
# Config => secret/elasticsearch-master-certs created
# Config => secret/elastic-jks created


# Install elastic components - elasticsearch
helm install elasticsearch elastic/elasticsearch -n c8-labs-32 -f elasticsearch.yaml
# if you see any issues, check the pod status - see command below
# After this, you should see below
# Storage: allocated under PersistentVolumeClaims (PVCs) in the namespace c8-labs-32
# with app elasticsearch-master (Look for Label: app=elasticsearch-master)
# Pod: elasticsearch-master-0 is running

