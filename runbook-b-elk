# this ends part 1 - elk installation


# Useful commands
kubectl api-resources --verbs=list --namespaced -o name | xargs -n 1 kubectl get --show-kind --ignore-not-found -n c8-labs-32

gcloud config set project c8-labs


# check pvs status
kubectl get pvc -n c8-labs-32
# check pod status
kubectl describe pod elasticsearch-master-0 -n c8-labs-32

# check ingress status
kubectl get pods -n kube-system | grep ingress

# check elasticsearch ingress
kubectl describe ingress elk-ingress -n c8-labs-32

# check elasticsearch ingress external IP address
kubectl get ingress elk-ingress -n c8-labs-32

kubectl get service elasticsearch-master -n c8-labs-32
kubectl describe service elasticsearch-master -n c8-labs-32


kubectl get svc kibana-kibana -n c8-labs-32
kubectl get endpoints kibana-kibana -n c8-labs-32


kubectl port-forward svc/kibana-kibana 5601:5601 -n c8-labs-32
curl -I http://localhost:5601/
curl -I http://localhost:5601/login


# Check if the user can create secrets in the namespace
kubectl auth can-i create secrets -n <namespace>

