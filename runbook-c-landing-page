# (Optional) The image is already pushed to GCR. 
# Build image again if you made any changes.
# Lets build a landing page to help navigate with camunda c8 components
cd nginx

# Build docker image
docker build -t asia-south2-docker.pkg.dev/c8-labs/c8-labs-repo/toolkit-c8-labs-nginx-static:v1 .

docker buildx build --platform linux/amd64,linux/arm64 -t asia-south2-docker.pkg.dev/c8-labs/c8-labs-repo/toolkit-c8-labs-nginx-static:v1 .

# Authenticate docker to push to GCR
docker push                   asia-south2-docker.pkg.dev/c8-labs/c8-labs-repo/toolkit-c8-labs-nginx-static:v1


#################
# Lets come back to the home folder and run deploy nginx static landing page to GKE
envsubst '${UNAMESPACE}' < deploy-landing-page.yaml  | kubectl apply -f -


kubectl describe service nginx-landing-page-service -n ${UNAMESPACE}

### Useful commands
kubectl delete deployment nginx-static-web-app -n ${UNAMESPACE} 
kubectl delete service nginx-landing-page-service  -n ${UNAMESPACE}

