# pre-requisites
# a. Make sure Docker is running
# b. You have access to GCP Kubernetes Engine (GKE) - to create cluster c8-labs-sravana
# c. Have node pool configured across locations - 1 node in each zone to start with.
# d. Make sure that node pool Provisioning model = Spot
# e. Make sure Cloud NAT is configured for the region where you are creating the cluster.


# open new terminal and connect to cluster - GKE.
# Sign in to GCP first using this command
gcloud auth login

################################
# (A.1) Grant access to the user - Developer or Viewer profile

export UNAME=Raghavendra.chari@gmail.com

#gcloud iam roles create CustomK8sRoleCreator --project=c8-labs --file=custom-k8s-role.yaml
#gcloud projects add-iam-policy-binding c8-labs --member="user:${UNAME}" --role="projects/c8-labs/roles/CustomK8sRoleCreator"

gcloud projects add-iam-policy-binding c8-labs --member="user:${UNAME}" --role="roles/container.clusterViewer"
gcloud projects add-iam-policy-binding c8-labs --member="user:${UNAME}" --role="roles/compute.viewer"
gcloud projects add-iam-policy-binding c8-labs --member="user:${UNAME}" --role="roles/viewer"

gcloud projects add-iam-policy-binding c8-labs --member="user:${UNAME}" --role="roles/container.developer"
gcloud projects add-iam-policy-binding c8-labs --member="user:${UNAME}" --role="roles/artifactregistry.writer"

################################
# (A.2) Create the cluster

# create cluster with necessary configurations (with default node pool)
# 
gcloud beta container --project "c8-labs" clusters create "c8-labs-sravana" \
  --region "asia-south2"  --no-enable-basic-auth \
  --cluster-version "1.33.2-gke.1111000" --release-channel "regular" \
  --machine-type "n2-standard-4" --image-type "COS_CONTAINERD" \
  --disk-type "pd-standard" --disk-size "50" --enable-autoscaling \
  --metadata disable-legacy-endpoints=true \
  --node-locations=asia-south2-a,asia-south2-b,asia-south2-c \
  --spot --num-nodes=1 --total-min-nodes=1 --total-max-nodes=12 \
  --logging=SYSTEM,WORKLOAD \
  --monitoring=SYSTEM \
  --enable-private-nodes --enable-ip-alias --network "projects/c8-labs/global/networks/default" \
  --subnetwork "projects/c8-labs/regions/asia-south2/subnetworks/default" \
  --no-enable-intra-node-visibility --default-max-pods-per-node "110" \
  --security-posture=standard \
  --workload-vulnerability-scanning=disabled --no-enable-google-cloud-access \
  --addons HorizontalPodAutoscaling,HttpLoadBalancing,GcePersistentDiskCsiDriver \
  --enable-autoupgrade --enable-autorepair --max-surge-upgrade 1 --max-unavailable-upgrade 0 \
  --binauthz-evaluation-mode=DISABLED --enable-managed-prometheus --enable-shielded-nodes \
  --shielded-integrity-monitoring --no-shielded-secure-boot \
  --autoscaling-profile optimize-utilization 

# optional config
gcloud container clusters update c8-labs-sravana --region "asia-south2" --enable-image-streaming

# Note: Need to sign in to GCP first using gcloud auth login
# After this step, you can use Project Lens UI app to view the cluster details.
gcloud container clusters get-credentials c8-labs-sravana --region asia-south2 --project c8-labs


################################
# (A.3) Create the namespace and role binding

# lets create a namespace - delete if it exists
# --namespace c8-labs-32
kubectl delete namespace c8-labs-32
export UNAMESPACE=c8-labs-32
envsubst '${UNAMESPACE}' < namespace-c86-mini.yaml  | kubectl apply -f -

# Provide "namespace access" to the user
# These are generally read-only permissions.
export UNAME=Raghavendra.chari@gmail.com
envsubst '${UNAME} ${UNAMESPACE}' < role-viewer-binding.yaml  | kubectl apply -f -

# Whereas these are "developer" permissions.
envsubst '${UNAME} ${UNAMESPACE}' < role-developer-binding.yaml  | kubectl apply -f -

# Add cert files as secrets
kubectl create secret tls cf-origin-cert \
  --cert=cert-public-c8-labs.key \
  --key=cert-key-c8-labs.key -n c8-labs-32

################################
# (A.4) Ngnix Ingress Controller - common for the cluster 
#     Normally shared with all namespaces 

helm repo add ingress-nginx https://kubernetes.github.io/ingress-nginx
helm repo update

# Use one of the following two options.
helm install nginx-ingress ingress-nginx/ingress-nginx --namespace c8-labs-ingress-nginx --create-namespace  \
  --set controller.config.enable-http2="true" \
  --set-string controller.config.proxy-buffer-size="16K" \
  --set-string controller.config.proxy-buffers="3 8K" \
  --set-string controller.config.proxy-busy-buffers-size="32K"

helm install nginx-ingress ingress-nginx/ingress-nginx --namespace c8-labs-ingress-nginx --create-namespace  \
  --set controller.config.enable-http2="true" \
  --set-string controller.config.proxy-buffer-size="128K" \
  --set-string controller.config.proxy-buffers="4 64K" \
  --set-string controller.config.proxy-busy-buffers-size="128K"

# try this one perhaps -> --set controller.config.ssl-redirect="false"

# [with right pod name] Check the status of the ingress controller pod - look for any config errors 
kubectl describe pod nginx-ingress-ingress-nginx-controller-75fc9f4654-68d5x -n c8-labs-32

# End of this part of runboook
########

# Useful commands
# create node pool with spot (optional - to add more capacity as necessary)
gcloud container node-pools create node-pool-swati-v2 \
        --cluster c8-labs-sravana \
        --machine-type n2-standard-4 \
        --disk-type=pd-standard \
        --disk-size=50 \
        --enable-autoscaling \
        --num-nodes=1 --min-nodes=1 --max-nodes=4  \
        --region asia-south2 \
        --node-locations=asia-south2-a,asia-south2-b,asia-south2-c \
        --spot

# Cluster optimize utilization profile 
# This is optional, but recommended to optimize the cluster utilization.
gcloud container clusters update c8-labs-sravana --region asia-south2 --autoscaling-profile optimize-utilization

# delete cluster
gcloud beta container --project "c8-labs" clusters delete "c8-labs-sravana"  --region "asia-south2"