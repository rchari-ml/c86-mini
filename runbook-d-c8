helm install prometheus prometheus-community/prometheus -f prometheus.yml --namespace c8-labs-32
# Grafana
helm repo add grafana https://grafana.github.io/helm-charts
helm repo update
helm install grafana grafana/grafana --namespace  c8-labs-32

kubectl get secret --namespace c8-labs-32 grafana -o jsonpath="{.data.admin-password}" | base64 --decode ; echo

kubectl apply -f c8-ingress-grafana.yaml --namespace c8-labs-32


